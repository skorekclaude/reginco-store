<section class="wrap" style="padding-top:40px">
  <h1 class="serif" style="font-size:38px">{{ 'cart.title' | t }}</h1>
  {%- if cart.item_count > 0 -%}
  <form action="{{ routes.cart_url }}" method="post" novalidate>
    <table style="width:100%;border-collapse:collapse;margin-top:24px">
      {%- for item in cart.items -%}
      <tr style="border-top:1px solid var(--line)">
        <td style="padding:16px 12px 16px 0;width:90px">
          {%- if item.image -%}<img src="{{ item.image | image_url: width: 160 }}" alt="" style="width:80px;height:80px;object-fit:cover;border-radius:6px">{%- endif -%}
        </td>
        <td style="padding:16px 12px">
          <a href="{{ item.url }}" class="serif" style="font-size:17px">{{ item.product.title }}</a>
          {%- unless item.variant.title contains 'Default' -%}<div style="color:var(--ink2);font-size:14px">{{ item.variant.title }}</div>{%- endunless -%}
        </td>
        <td style="padding:16px 12px">
          <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;padding:8px;border:1px solid var(--line);border-radius:6px">
        </td>
        <td style="padding:16px 0;text-align:right;font-weight:500">{{ item.final_line_price | money }}</td>
      </tr>
      {%- endfor -%}
    </table>
    <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--line);margin-top:20px;padding-top:20px;flex-wrap:wrap;gap:16px">
      <button type="submit" name="update" class="btn" style="background:transparent;border:1px solid var(--line);color:var(--ink)">{{ 'cart.update' | t }}</button>
      <div style="text-align:right">
        <div style="color:var(--ink2);font-size:14px">{{ 'cart.subtotal' | t }}</div>
        <div class="serif" style="font-size:28px">{{ cart.total_price | money }}</div>
      </div>
    </div>
    <div style="margin-top:18px;text-align:right">
      <button type="submit" name="checkout" class="btn">{{ 'cart.checkout' | t }}</button>
    </div>
  </form>
  {%- else -%}
  <p style="padding:40px 0;color:var(--ink2)">{{ 'cart.empty' | t }}</p>
  <a href="{{ routes.all_products_collection_url }}" class="btn">{{ 'cart.continue' | t }}</a>
  {%- endif -%}
</section>

{% schema %}
{ "name": "Koszyk", "settings": [] }
{% endschema %}
