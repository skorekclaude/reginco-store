<footer>
  <div class="wrap">
    <div class="fcols">
      <div>
        <div class="logo">REGINC<span style="color:var(--cork)">Ó</span>S</div>
        <p style="max-width:36ch;font-size:14px">{{ section.settings.tagline }}</p>
      </div>
      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
        <div {{ block.shopify_attributes }}>
          <h5>{{ block.settings.heading }}</h5>
          {%- for link in linklists[block.settings.menu].links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="fbot">
      <span>© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      <span>{{ section.settings.baseline }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Ferramentas de cabelo feitas à mão em Espanha, em cortiça e madeira, desde 1987. O Cork Grip original." },
    { "type": "text", "id": "baseline", "label": "Linia dolna", "default": "Cortiça · Madeira · Ofício · Desde 1987" }
  ],
  "blocks": [
    { "type": "menu", "name": "Kolumna menu", "settings": [
      { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Loja" },
      { "type": "link_list", "id": "menu", "label": "Menu" }
    ]}
  ],
  "default": {
    "blocks": [ { "type": "menu" }, { "type": "menu" }, { "type": "menu" } ]
  }
}
{% endschema %}
