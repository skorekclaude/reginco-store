<header class="hero">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 1800 | image_tag: class: 'bg', alt: section.settings.heading }}
  {%- endif -%}
  <div class="wrap inner">
    {%- if section.settings.kicker != blank -%}<div class="upper kick">{{ section.settings.kicker }}</div>{%- endif -%}
    <h1 class="serif">{{ section.settings.heading }}</h1>
    {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    {%- if section.settings.btn1_label != blank -%}<a class="btn" href="{{ section.settings.btn1_link }}">{{ section.settings.btn1_label }}</a>{%- endif -%}
    {%- if section.settings.btn2_label != blank -%}<a class="btn ghost" href="{{ section.settings.btn2_link }}">{{ section.settings.btn2_label }}</a>{%- endif -%}
  </div>
</header>
{%- if section.settings.show_values -%}
<div class="values">
  {%- for block in section.blocks -%}
    <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
  {%- endfor -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Zdjęcie tła" },
    { "type": "text", "id": "kicker", "label": "Nadtytuł", "default": "O Cork Grip · desde 1987" },
    { "type": "inline_richtext", "id": "heading", "label": "Nagłówek", "info": "Owiń jedno słowo w <em>…</em> dla akcentu kursywą cork", "default": "Escovas esculpidas pela <em>natureza</em>." },
    { "type": "textarea", "id": "text", "label": "Tekst", "default": "O revolucionário sistema cork-grip, inventado pela Regincós em 1987." },
    { "type": "text", "id": "btn1_label", "label": "Przycisk 1", "default": "Ver a série cortiça" },
    { "type": "url", "id": "btn1_link", "label": "Link 1" },
    { "type": "text", "id": "btn2_label", "label": "Przycisk 2", "default": "A nossa história" },
    { "type": "url", "id": "btn2_link", "label": "Link 2" },
    { "type": "checkbox", "id": "show_values", "label": "Pokaż pasek wartości", "default": true }
  ],
  "blocks": [
    { "type": "value", "name": "Wartość", "settings": [ { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p><strong>1987</strong> · Ofício espanhol</p>" } ] }
  ],
  "default": { "blocks": [ {"type":"value"}, {"type":"value"}, {"type":"value"}, {"type":"value"} ] },
  "presets": [ { "name": "Hero" } ]
}
{% endschema %}
