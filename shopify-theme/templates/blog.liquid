<section class="wrap" style="padding:60px 0"><h1 class="serif" style="font-size:42px">{{ blog.title }}</h1>{% for article in blog.articles %}<article style="border-top:1px solid var(--line);padding:24px 0"><a href="{{ article.url }}" class="serif" style="font-size:24px">{{ article.title }}</a><p style="color:var(--ink2)">{{ article.excerpt_or_content | strip_html | truncatewords: 30 }}</p></article>{% endfor %}</section>