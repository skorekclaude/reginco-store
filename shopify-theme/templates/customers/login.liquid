<section class="wrap" style="padding:60px 0;max-width:420px"><h1 class="serif" style="font-size:34px;margin-bottom:20px">{{ 'customer.log_in' | t }}</h1>{% form 'customer_login' %}<input type="email" name="customer[email]" placeholder="{{ 'customer.email' | t }}" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:6px;margin-bottom:12px"><input type="password" name="customer[password]" placeholder="{{ 'customer.password' | t }}" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:6px;margin-bottom:16px"><button class="btn" type="submit">{{ 'customer.log_in' | t }}</button>{% endform %}</section>