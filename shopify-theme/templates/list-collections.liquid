<section class="wrap" style="padding:60px 0"><h1 class="serif" style="font-size:42px;margin-bottom:30px">Coleções</h1><div class="bento">{% for collection in collections %}<a class="cell" href="{{ collection.url }}">{% if collection.featured_image %}{{ collection.featured_image | image_url: width: 800 | image_tag: alt: collection.title }}{% endif %}<div class="lbl"><div class="t serif">{{ collection.title }}</div></div></a>{% endfor %}</div></section>