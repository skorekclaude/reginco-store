<section class="wrap" style="padding:60px 0"><h1 class="serif" style="font-size:38px">{{ 'general.search.search' | t }}</h1><form action="{{ routes.search_url }}" method="get"><input type="search" name="q" value="{{ search.terms | escape }}" style="width:100%;max-width:480px;padding:12px;border:1px solid var(--line);border-radius:6px;margin:18px 0"></form>{% if search.performed %}<div class="grid4">{% for item in search.results %}{% if item.object_type == 'product' %}{% render 'card-product', card_product: item %}{% endif %}{% endfor %}</div>{% endif %}</section>